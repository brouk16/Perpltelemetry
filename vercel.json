{
  "buildCommand": "pnpm --filter @workspace/perpl-stats run build:vercel",
  "outputDirectory": "vercel-out",
  "installCommand": "pnpm install --frozen-lockfile",
  "framework": null,
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/server" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
